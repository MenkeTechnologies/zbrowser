+// zwire HUD final override. AddChromeColorMixer sets the tab wells from the HUD
+// palette, but the Material tab-strip mixer (AddMaterialTabStripColorMixer) and
+// the native chrome mixer run AFTER it and re-point the tab background at GM3
+// "Sys" tokens (kColorSysBase / kColorSysOnSurface) whose dynamic values ignore
+// the HUD palette — so the active tab paints a scheme-independent GM3 default
+// (the long-standing "always red" tab). Re-assert the tab colors DIRECTLY (not
+// via a Sys reference) from the active scheme in a mixer added dead-last, so the
+// HUD wins no matter how the upstream tab-strip mixers are ordered.
+void AddZwireHudFinalMixer(ui::ColorProvider* provider,
+                           const ui::ColorProviderKey& key) {
+  EnsureHudSchemeWatcher();
+  const HudScheme& hs = ActiveHudScheme();
+  ui::ColorMixer& mixer = provider->AddMixer();
+  // Tab wells — direct scheme colors (card bg for active, primary bg for rest).
+  mixer[kColorTabBackgroundActiveFrameActive] = {hs.c};
+  mixer[kColorTabBackgroundActiveFrameInactive] = {hs.c};
+  mixer[kColorTabBackgroundInactiveFrameActive] = {hs.p};
+  mixer[kColorTabBackgroundInactiveFrameInactive] = {hs.p};
+  mixer[kColorDetachedTabBackgroundActiveFrameActive] = {hs.c};
+  // Hover + selected tab wells — the Material tab-strip mixer points these at GM3
+  // "Sys" state tokens (kColorSysStateHeaderHover / …HeaderSelect) that ignore
+  // the HUD palette, so hovering an inactive tab flashed a GM3-default (red)
+  // background. Pin them to the scheme's hover/secondary bg.
+  mixer[kColorTabBackgroundInactiveHoverFrameActive] = {hs.h};
+  mixer[kColorTabBackgroundInactiveHoverFrameInactive] = {hs.h};
+  mixer[kColorTabBackgroundSelectedFrameActive] = {hs.s};
+  mixer[kColorTabBackgroundSelectedFrameInactive] = {hs.s};
+  mixer[kColorTabBackgroundSelectedHoverFrameActive] = {hs.h};
+  mixer[kColorTabBackgroundSelectedHoverFrameInactive] = {hs.h};
+  // Tab labels — accent on the active tab, dim text on the rest.
+  mixer[kColorTabForegroundActiveFrameActive] = {hs.a};
+  mixer[kColorTabForegroundActiveFrameInactive] = {hs.a};
+  mixer[kColorTabForegroundInactiveFrameActive] = {hs.td};
+  mixer[kColorTabForegroundInactiveFrameInactive] = {hs.td};
+  // Neon tab outline: cyan when focused, magenta when blurred.
+  mixer[kColorTabStrokeFrameActive] = {hs.cy};
+  mixer[kColorTabStrokeFrameInactive] = {hs.m};
+}
