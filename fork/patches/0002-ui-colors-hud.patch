+// ---- zwire HUD scheme system -------------------------------------------
+// The 8 strykelang schemes, baked native. The active one is chosen by the
+// color-scheme picker (a content-script extension), which drives zwire-host to
+// write ~/.zwire/hud-scheme; a FilePathWatcher live-repaints the chrome.
+struct HudScheme {
+  const char* name;
+  SkColor p, s, c, h;      // bg: primary, secondary, card, hover
+  SkColor t, td;           // text, text-dim
+  SkColor a, cy, m, b;     // accent(hot), cyan, magenta, border
+};
+constexpr HudScheme kHudSchemes[] = {
+  {"cyberpunk", 0xFF05050A,0xFF0A0A14,0xFF0D0D1A,0xFF12122A, 0xFFE0F0FF,0xFF7A8BA8, 0xFFFF2A6D,0xFF05D9E8,0xFFD300C5,0xFF1A1A3E},
+  {"midnight",  0xFF020617,0xFF0F172A,0xFF1E293B,0xFF334155, 0xFFE2E8F0,0xFF94A3B8, 0xFF7C3AED,0xFF38BDF8,0xFF6366F1,0xFF334155},
+  {"matrix",    0xFF000500,0xFF001A00,0xFF002A00,0xFF003A00, 0xFFD4FFD4,0xFF7CCC7C, 0xFF00FF41,0xFF00FFCC,0xFF008F39,0xFF004D00},
+  {"ember",     0xFF0A0503,0xFF1A0F05,0xFF27150A,0xFF3A1F0F, 0xFFFED7AA,0xFFD97706, 0xFFF97316,0xFFFBBF24,0xFFDC2626,0xFF4A2C17},
+  {"arctic",    0xFF020617,0xFF0C1424,0xFF0F1E33,0xFF1E2F4D, 0xFFE0F2FE,0xFF7DD3FC, 0xFF60A5FA,0xFF22D3EE,0xFF818CF8,0xFF1E3A5F},
+  {"crimson",   0xFF0A0506,0xFF140A0C,0xFF1A0D10,0xFF2A1318, 0xFFFFE4E6,0xFFB08A92, 0xFFE11D48,0xFF2DD4BF,0xFFF43F5E,0xFF3E1A22},
+  {"toxic",     0xFF07090A,0xFF0C0F0A,0xFF0F130C,0xFF161B10, 0xFFE8FFD0,0xFF8A9A6A, 0xFFC6FF00,0xFF00E5FF,0xFFFF00AA,0xFF2A3A1A},
+  {"vapor",     0xFF0D0814,0xFF140D1F,0xFF1A1228,0xFF241836, 0xFFF0E6FF,0xFFA99CC4, 0xFFFF6EC7,0xFF72F1FF,0xFFC792EA,0xFF2E2142},
+};
+constexpr int kHudSchemeCount = sizeof(kHudSchemes) / sizeof(kHudSchemes[0]);
+
+std::atomic<int>& HudSchemeIndex() {
+  static std::atomic<int> index{0};
+  return index;
+}
+
+base::FilePath HudSchemeDir() {
+  // The shared, app-independent zwire theme dir: ~/.zwire — one location the
+  // whole fleet (every app + zwire-host) reads/writes, so the native chrome
+  // follows the same colour scheme as everything else. zwire-host writes a plain
+  // `hud-scheme` text projection here beside the canonical global.toml.
+  base::FilePath home;
+  base::PathService::Get(base::DIR_HOME, &home);
+  return home.Append(".zwire");
+}
+
+void ReadHudSchemeFile() {
+  std::string contents;
+  if (!base::ReadFileToString(HudSchemeDir().Append("hud-scheme"), &contents))
+    return;
+  std::string name(base::TrimWhitespaceASCII(contents, base::TRIM_ALL));
+  int idx = 0;
+  for (const auto& scheme : kHudSchemes) {
+    if (name == scheme.name) {
+      HudSchemeIndex().store(idx);
+      return;
+    }
+    ++idx;
+  }
+}
+
+void OnHudSchemeChanged(const base::FilePath&, bool) {
+  int before = HudSchemeIndex().load();
+  ReadHudSchemeFile();
+  if (HudSchemeIndex().load() != before) {
+    // Rebuild all color providers + repaint (same path as OS theme changes).
+    ui::NativeTheme::GetInstanceForNativeUi()->NotifyOnNativeThemeUpdated();
+    ui::NativeTheme::GetInstanceForWeb()->NotifyOnNativeThemeUpdated();
+  }
+}
+
+void StartHudSchemeWatcherOnUI() {
+  static base::NoDestructor<base::FilePathWatcher> watcher;
+  static bool started = false;
+  if (started)
+    return;
+  started = true;
+  ReadHudSchemeFile();
+  // Watch the directory (it exists; the file may be created later by the picker).
+  watcher->Watch(HudSchemeDir(), base::FilePathWatcher::Type::kNonRecursive,
+                 base::BindRepeating(&OnHudSchemeChanged));
+}
+
+void EnsureHudSchemeWatcher() {
+  static bool posted = false;
+  if (posted)
+    return;
+  posted = true;
+  content::GetUIThreadTaskRunner({})->PostTask(
+      FROM_HERE, base::BindOnce(&StartHudSchemeWatcherOnUI));
+}
+
+const HudScheme& ActiveHudScheme() {
+  int i = HudSchemeIndex().load();
+  if (i < 0 || i >= kHudSchemeCount)
+    i = 0;
+  return base::span(kHudSchemes)[static_cast<size_t>(i)];
+}
