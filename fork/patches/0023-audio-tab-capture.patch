 // Get the id of the allowlisted extension.
 std::string GetAllowlistedExtensionID() {
-  return base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+  std::string id = base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
       switches::kAllowlistedExtensionID);
+  // zwire HUD (fork patch 0023): allowlist the internal HUD extension for tab
+  // capture so the Audio dashboard (audio.html) can snoop any audible tab's
+  // output into its analyzer/EQ chain via tabCapture.getMediaStreamId — with no
+  // manifest permission, no activeTab grant, and no picker/prompt. Only applied
+  // when --allowlisted-extension-id is otherwise unset, and only grants this one
+  // id, so no other extension's capture behavior changes.
+  if (id.empty()) {
+    id = "omcgnnjfmbmpdlofklbpddkhnfibfhgg";
+  }
+  return id;
 }
 
