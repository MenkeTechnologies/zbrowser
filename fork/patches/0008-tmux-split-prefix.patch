+  // zwire: tmux-style Ctrl-B prefix drives the native 2-pane split view.
+  // Ctrl-B arms the prefix; the next key is interpreted as a pane command and
+  // consumed so it never reaches web content.
+  if (event.GetType() == blink::WebInputEvent::Type::kRawKeyDown) {
+    if (tmux_prefix_armed_) {
+      const ui::KeyboardCode kc = accelerator.key_code();
+      // Wait for the real command key — ignore lone modifier presses.
+      if (kc == ui::VKEY_SHIFT || kc == ui::VKEY_CONTROL ||
+          kc == ui::VKEY_MENU || kc == ui::VKEY_COMMAND) {
+        return content::KeyboardEventProcessingResult::HANDLED;
+      }
+      tmux_prefix_armed_ = false;
+      if (kc != ui::VKEY_ESCAPE) {
+        HandleTmuxPrefixKey(accelerator);
+      }
+      return content::KeyboardEventProcessingResult::HANDLED;
+    }
+    if (accelerator.key_code() == ui::VKEY_B &&
+        accelerator.modifiers() == ui::EF_CONTROL_DOWN) {
+      tmux_prefix_armed_ = true;
+      // NOT_HANDLED (not consumed) so the event still reaches the page, letting
+      // the HUD statusbar light its prefix indicator. The following command key
+      // is consumed above.
+      return content::KeyboardEventProcessingResult::NOT_HANDLED;
+    }
+  }
