+// zwire: dispatch a tmux pane command (the key pressed after the Ctrl-B prefix)
+// against the native side-by-side split view.
+void BrowserView::HandleTmuxPrefixKey(const ui::Accelerator& accelerator) {
+  TabStripModel* model = browser_->tab_strip_model();
+  if (!model) {
+    return;
+  }
+  auto other_split_index = [&]() -> std::optional<int> {
+    if (!model->IsActiveTabSplit()) {
+      return std::nullopt;
+    }
+    std::optional<split_tabs::SplitTabId> id =
+        model->GetSplitForTab(model->active_index());
+    if (!id) {
+      return std::nullopt;
+    }
+    gfx::Range range = model->GetSplitData(id.value())->GetIndexRange();
+    const int first = static_cast<int>(range.GetMin());
+    const int second = static_cast<int>(range.GetMax()) - 1;
+    return model->active_index() == first ? second : first;
+  };
+  switch (accelerator.key_code()) {
+    case ui::VKEY_5:      // C-b %  : split (side-by-side; Chromium's only layout)
+    case ui::VKEY_OEM_7:  // C-b "  : split
+      chrome::ExecuteCommand(browser_.get(), IDC_NEW_SPLIT_TAB);
+      break;
+    case ui::VKEY_X:      // C-b x  : close the active pane
+      chrome::ExecuteCommand(browser_.get(), IDC_CLOSE_TAB);
+      break;
+    case ui::VKEY_O:      // C-b o  : focus the other pane
+    case ui::VKEY_OEM_1:  // C-b ;
+    case ui::VKEY_LEFT:   // C-b ←/→ : focus a pane by direction
+    case ui::VKEY_RIGHT:
+      if (std::optional<int> idx = other_split_index()) {
+        model->ActivateTabAt(idx.value());
+      }
+      break;
+    case ui::VKEY_OEM_4:  // C-b [ / {  : swap the two panes
+    case ui::VKEY_OEM_6:  // C-b ] / }
+      if (model->IsActiveTabSplit()) {
+        std::optional<split_tabs::SplitTabId> id =
+            model->GetSplitForTab(model->active_index());
+        if (id) {
+          model->ReverseTabsInSplit(id.value());
+        }
+      }
+      break;
+    default:
+      break;
+  }
+}
