+// zwire HUD live output-EQ sync (fork patch 0024) --------------------------
+// The audio service (sandboxed) can't read $STATE/audio-eq, so the (unsandboxed)
+// browser process polls it off-thread and pushes the spec to the service on
+// change via mojom AudioService::SetZwireEqConfig — reshaping all output live.
+base::FilePath ZwireEqFilePath() {
+  std::unique_ptr<base::Environment> env = base::Environment::Create();
+  std::optional<std::string> st = env->GetVar("ZWIRE_STATE");
+  if (st && !st->empty()) {
+    return base::FilePath(*st).Append("audio-eq");
+  }
+  base::FilePath dir;
+#if BUILDFLAG(IS_MAC)
+  if (base::PathService::Get(base::DIR_APP_DATA, &dir)) {
+    return dir.Append("com.menketechnologies.zwire").Append("audio-eq");
+  }
+#else
+  std::optional<std::string> xdg = env->GetVar("XDG_CONFIG_HOME");
+  if (xdg && !xdg->empty()) {
+    return base::FilePath(*xdg).Append("zwire").Append("audio-eq");
+  }
+  if (base::PathService::Get(base::DIR_HOME, &dir)) {
+    return dir.Append(".config").Append("zwire").Append("audio-eq");
+  }
+#endif
+  return base::FilePath();
+}
+
+std::string ReadZwireEqFileBlocking() {
+  base::FilePath p = ZwireEqFilePath();
+  std::string s;
+  if (!p.empty()) {
+    base::ReadFileToString(p, &s);
+  }
+  std::string trimmed;
+  base::TrimWhitespaceASCII(s, base::TRIM_ALL, &trimmed);
+  return trimmed;
+}
+
+std::string& LastZwireEqSpec() {
+  static base::NoDestructor<std::string> s;
+  return *s;
+}
+
+void OnZwireEqRead(const std::string& spec) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  if (spec == LastZwireEqSpec()) {
+    return;  // no change — avoid churning the audio-thread cascade rebuild
+  }
+  LastZwireEqSpec() = spec;
+  VLOG(1) << "zwire-eq-push: spec='" << spec << "'";
+  GetAudioService().SetZwireEqConfig(spec);
+}
+
+void PollZwireEqOnce() {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::BEST_EFFORT},
+      base::BindOnce(&ReadZwireEqFileBlocking), base::BindOnce(&OnZwireEqRead));
+}
+
+void EnsureZwireEqSyncStarted() {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  static base::NoDestructor<base::RepeatingTimer> timer;
+  if (timer->IsRunning()) {
+    return;
+  }
+  PollZwireEqOnce();
+  // 25ms poll: the file read is on the ThreadPool and pushes over mojo only on a
+  // real change (cache-guarded), so the cost is negligible but knob→engine latency
+  // drops from up-to-100ms of poll granularity to up-to-25ms. Combined with the
+  // page's ~20ms debounce + direct fs_write, knob response is ~40-50ms.
+  timer->Start(FROM_HERE, base::Milliseconds(25),
+               base::BindRepeating(&PollZwireEqOnce));
+}
+
+// zwire HUD output-meter pump (fork patch 0025): pull a compact meter frame from
+// the audio service each tick and atomically write it to $STATE/meters, which
+// the native host streams to the HUD Audio charts (no page-side tab capture).
+base::FilePath ZwireMetersFilePath() {
+  base::FilePath eq = ZwireEqFilePath();
+  return eq.empty() ? eq : eq.DirName().Append("meters");
+}
+
+void WriteZwireMetersBlocking(const std::string& json) {
+  base::FilePath p = ZwireMetersFilePath();
+  if (p.empty() || json.empty()) {
+    return;
+  }
+  // Atomic-ish: write temp then rename so the host never reads a torn frame.
+  base::FilePath tmp = p.AddExtension(FILE_PATH_LITERAL("tmp"));
+  bool w = base::WriteFile(tmp, json);
+  bool r = w && base::ReplaceFile(tmp, p, nullptr);
+  static int n = 0;
+  if ((n++ % 60) == 0) {
+    VLOG(1) << "zwire-meters-write: path=" << p.value() << " len=" << json.size()
+               << " write=" << w << " replace=" << r;
+  }
+}
+
+// The meter pump. Lives entirely on a ThreadPool sequence (NOT the UI thread) so
+// it keeps producing frames during a scroll/trackpad gesture, which saturates the
+// UI thread — the old UI-thread timer+mojo pump starved to <1 fps under a gesture,
+// freezing the meter file and the HUD Audio charts. It owns a ZwireMeters remote
+// (bound via the one-time UI hop in BindZwireMetersFromAnySequence), pulls a frame
+// every 33 ms, and writes the file on this same MayBlock sequence.
+class ZwireMeterPump {
+ public:
+  ZwireMeterPump() = default;
+
+  // Runs on the pump sequence.
+  void Start() {
+    Rebind();
+    timer_.Start(FROM_HERE, base::Milliseconds(33),
+                 base::BindRepeating(&ZwireMeterPump::Tick,
+                                     base::Unretained(this)));
+  }
+
+ private:
+  void Rebind() {
+    remote_.reset();
+    BindZwireMetersFromAnySequence(remote_.BindNewPipeAndPassReceiver());
+    remote_.set_disconnect_handler(base::BindOnce(
+        &ZwireMeterPump::OnDisconnect, base::Unretained(this)));
+  }
+
+  void Tick() {
+    // Don't stack calls if the service is momentarily slow; skip this tick.
+    if (!remote_ || pending_) {
+      return;
+    }
+    pending_ = true;
+    remote_->Pull(
+        base::BindOnce(&ZwireMeterPump::OnPulled, base::Unretained(this)));
+  }
+
+  void OnPulled(const std::string& json) {
+    pending_ = false;
+    static int n = 0;
+    if ((n++ % 90) == 0) {
+      VLOG(1) << "zwire-meters-pull(pool): len=" << json.size();
+    }
+    if (!json.empty()) {
+      WriteZwireMetersBlocking(json);  // same MayBlock sequence
+    }
+  }
+
+  void OnDisconnect() {
+    // Audio service went away (e.g. restarted). Rebind — the next Pull relaunches
+    // it via GetAudioService() on the UI hop.
+    pending_ = false;
+    Rebind();
+  }
+
+  mojo::Remote<audio::mojom::ZwireMeters> remote_;
+  base::RepeatingTimer timer_;
+  bool pending_ = false;
+};
+
+void EnsureZwireMeterPumpStarted() {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+  static base::NoDestructor<base::SequenceBound<ZwireMeterPump>> pump(
+      base::ThreadPool::CreateSequencedTaskRunner(
+          {base::MayBlock(), base::TaskPriority::USER_VISIBLE}));
+  static bool started = false;
+  if (started) {
+    return;
+  }
+  started = true;
+  pump->AsyncCall(&ZwireMeterPump::Start);
+}
