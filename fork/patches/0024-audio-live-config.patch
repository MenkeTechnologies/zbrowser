+// zwire HUD (fork patch 0025) — bind a ZwireMeters receiver. The bind itself must
+// happen on the UI thread (that is where the AudioService remote lives), but the
+// resulting ZwireMeters remote is then driven from the caller's sequence — so the
+// meter pump can run entirely off the UI thread (see ZwireMeterPump below).
+void BindZwireMetersFromAnySequence(
+    mojo::PendingReceiver<audio::mojom::ZwireMeters> receiver) {
+  if (!BrowserThread::CurrentlyOn(BrowserThread::UI)) {
+    GetUIThreadTaskRunner({})->PostTask(
+        FROM_HERE,
+        base::BindOnce(&BindZwireMetersFromAnySequence, std::move(receiver)));
+    return;
+  }
+  GetAudioService().BindZwireMeters(std::move(receiver));
+}
