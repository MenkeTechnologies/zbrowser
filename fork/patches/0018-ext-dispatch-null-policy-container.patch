diff --git a/extensions/browser/extension_function_dispatcher.cc b/extensions/browser/extension_function_dispatcher.cc
index 40f32158df..825bac1d3c 100644
--- a/extensions/browser/extension_function_dispatcher.cc
+++ b/extensions/browser/extension_function_dispatcher.cc
@@ -437,9 +437,18 @@ void ExtensionFunctionDispatcher::DispatchWithCallbackInternal(
     // Since sandboxed frames listed in the manifest don't get access to the
     // extension APIs, this will only be true in an extension frame in an iframe
     // with the sandbox attribute specified, or served with a CSP header.
+    // zwire: an async extension-function IPC can be processed after the
+    // requesting frame has left the active lifecycle (pending-deletion or
+    // speculative during a navigation — e.g. the Chrome Web Store's
+    // top-charts nav). Such a RenderFrameHostImpl has a null
+    // policy_container_host_, so IsSandboxed() -> active_sandbox_flags()
+    // hits NOTREACHED() (crbug.com/455908853) and crashes the browser
+    // process. is_sandboxed only feeds UMA below, so gate it on IsActive()
+    // — a committed active document always has a policy container.
     bool is_sandboxed =
-        render_frame_host && render_frame_host->IsSandboxed(
-                                 network::mojom::WebSandboxFlags::kOrigin);
+        render_frame_host && render_frame_host->IsActive() &&
+        render_frame_host->IsSandboxed(
+            network::mojom::WebSandboxFlags::kOrigin);
     // Note: Deliberately don't include external component extensions here -
     // this lets us differentiate between "built-in" extension calls and
     // external extension calls
