# runtime state (base browser + profile) never lives in the repo
.zwire/
# Chromium compiles loaded themes into this cache inside theme/
Cached Theme.pak
# The global gitignore drops *.patch — but the fork patch series MUST be tracked
!fork/patches/*.patch
node_modules/
*.log
.DS_Store

# Chrome writes _metadata/ into keyed unpacked extensions at load time
extensions/*/_metadata/
extensions/*/*/_metadata/
newtab/_metadata/

# macOS release artifacts (scripts/release-macos.sh)
dist/
